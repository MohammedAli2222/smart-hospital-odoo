<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_inherit_pulse" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.pulse</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="is_critical_iot_alert" invisible="1"/>
                <field name="patient_heart_rate" 
                       string="Heart Rate (BPM)"
                       decoration-danger="is_critical_iot_alert == True" 
                       decoration-bf="is_critical_iot_alert == True"/>
            </xpath>
        </field>
    </record>
</odoo>