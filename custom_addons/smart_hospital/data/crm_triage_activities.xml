<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="demo_emergency_red_flag" model="mail.activity">
            <field name="res_model_id" ref="crm.model_crm_lead"/>
            <field name="res_id" eval="ref('demo_emergency_ticket')"/>
            <field name="activity_type_id" ref="mail.mail_activity_data_call"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="summary">Immediate Follow-up</field>
            <field name="note">High-priority trauma case! Immediate dispatch required.</field>
            <field name="date_deadline" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d')"/>
        </record>
        
    </data>
</odoo>