<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_smart_hospital" model="ir.module.category">
            <field name="name">Smart Hospital Management</field>
            <field name="description">Security access levels for Smart Mobile Hospital ERP roles.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_medical_operations_manager" model="res.groups">
            <field name="name">Medical Operations Manager</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('project.group_project_manager')), (4, ref('hr.group_hr_user'))]"/>
            <field name="comment">مسؤول عن إدارة العمليات الطبية الميدانية والمشاريع مع صلاحيات عرض المخزون والموظفين.</field>
        </record>

        <record id="group_doctor_clinician" model="res.groups">
            <field name="name">Doctor / Clinician</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('project.group_project_user'))]"/>
            <field name="comment">الأطباء والممارسون الطبيون في الميدان لادارة مهامهم وطلب الاحتياجات الطبية.</field>
        </record>

        <record id="group_receptionist_dispatcher" model="res.groups">
            <field name="name">Receptionist / Dispatcher</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('account.group_account_invoice'))]"/>
            <field name="comment">موظفو الاستقبال وتوجيه مركبات الإسعاف مع صلاحية إنشاء الفواتير المبدئية فقط.</field>
        </record>

        <record id="group_medical_inventory_officer" model="res.groups">
            <field name="name">Medical Inventory Officer</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_manager')), (4, ref('purchase.group_purchase_user')), (4, ref('maintenance.group_equipment_manager'))]"/>
            <field name="comment">إدارة المستودعات الطبية بشكل كامل مع صلاحيات لوجستية وصيانة المعدات وتأكيد طلبات الشراء المتداخلة.</field>
        </record>

        <record id="group_procurement_manager" model="res.groups">
            <field name="name">Procurement Manager</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_manager')), (4, ref('stock.group_stock_user'))]"/>
            <field name="comment">المسؤول عن التوريد وإدارة عمليات الشراء والمشتريات الطبية واعتماد الموردين.</field>
        </record>

        <record id="group_maintenance_technician" model="res.groups">
            <field name="name">Maintenance Technician</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('maintenance.group_equipment_manager'))]"/>
            <field name="comment">فني صيانة الأجهزة الطبية وسيارات الإسعاف مع صلاحية طلب قطع الغيار من المستودعات.</field>
        </record>

        <record id="group_accountant" model="res.groups">
            <field name="name">Accountant</field>
            <field name="category_id" ref="module_category_smart_hospital"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_manager')), (4, ref('purchase.group_purchase_user'))]"/>
            <field name="comment">المسؤول المالي لمطابقة فواتير المشتريات وإدارة الحسابات العامة ودفاتر الأستاذ للمستشفى.</field>
        </record>

    </data>
</odoo>